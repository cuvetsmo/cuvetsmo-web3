# Copy to .env.local and fill in real values.
# All NEXT_PUBLIC_* values are bundled into the client — never put secrets there.

# ────────────────────────────────────────────────────
# Privy (auth + embedded wallets)
# Sign up at https://dashboard.privy.io and create an app for Base Sepolia.
# ────────────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=

# ────────────────────────────────────────────────────
# Base Sepolia RPC
# Default public RPC works for low traffic. Upgrade to Alchemy/Infura/QuickNode
# when you start hitting rate limits.
# ────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org

# ────────────────────────────────────────────────────
# Contract addresses — Agent A populates after deploying to Base Sepolia.
# Until they're set, lib/contracts.ts falls back to the zero address.
# ────────────────────────────────────────────────────
NEXT_PUBLIC_ORG_REGISTRY_ADDRESS=
NEXT_PUBLIC_VET_SBT_CARD_ADDRESS=
NEXT_PUBLIC_BADGE_REGISTRY_ADDRESS=
NEXT_PUBLIC_FIRST_STEPS_SBT_ADDRESS=
NEXT_PUBLIC_GUESTBOOK_ADDRESS=
NEXT_PUBLIC_TOKEN_IMPL_ADDRESS=
NEXT_PUBLIC_TOKEN_FACTORY_ADDRESS=
NEXT_PUBLIC_NFT_IMPL_ADDRESS=
NEXT_PUBLIC_NFT_FACTORY_ADDRESS=
NEXT_PUBLIC_SBT_FACTORY_ADDRESS=
NEXT_PUBLIC_GOVERNOR_FACTORY_ADDRESS=

# ────────────────────────────────────────────────────
# Pinata (IPFS pinning for NFT metadata + images)
# Sign up at https://app.pinata.cloud
# ────────────────────────────────────────────────────
NEXT_PUBLIC_PINATA_GATEWAY=
PINATA_JWT=

# ────────────────────────────────────────────────────
# Pimlico (gas sponsorship via ERC-4337 paymaster)
# Sign up at https://dashboard.pimlico.io
# Server-side only — DO NOT prefix with NEXT_PUBLIC_.
# ────────────────────────────────────────────────────
PIMLICO_API_KEY=

# ────────────────────────────────────────────────────
# Faucet server wallet (Agent B uses this to dispense testnet ETH)
# Server-side only.
# ────────────────────────────────────────────────────
FAUCET_PRIVATE_KEY=

# ────────────────────────────────────────────────────
# Badge minter — server admin key that calls BadgeRegistry.mint() after
# a quest is verified by /api/quests/[id]/verify. Server-side only.
# If unset, verified quests return mintPending=true so XP is still tracked.
# ────────────────────────────────────────────────────
BADGE_MINTER_PRIVATE_KEY=
